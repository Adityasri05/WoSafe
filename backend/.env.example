# ============================================
# WoSafe Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────
APP_NAME=WoSafe
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=DEBUG

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql+asyncpg://wosafe:wosafe_password@localhost:5432/wosafe_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── JWT Authentication ───────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase ─────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Google Gemini AI ─────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# ── Mapbox ───────────────────────────────────
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# ── Google Maps ──────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Twilio (SMS & Voice) ────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VOICE_URL=https://your-domain.com/api/v1/voice/webhook

# ── Resend (Email) ──────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=safety@wosafe.app

# ── SendGrid (Email Fallback) ───────────────
SENDGRID_API_KEY=your-sendgrid-api-key

# ── Cloudinary (File Storage) ───────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Celery ──────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Encryption ──────────────────────────────
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ── Prometheus ──────────────────────────────
PROMETHEUS_ENABLED=true
