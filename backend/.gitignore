*.db
*.sqlite3

# Logs
logs/
*.log

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Test
.coverage
htmlcov/
.pytest_cache/
test.db

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic
alembic/versions/*.pyc
